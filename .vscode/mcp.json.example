{
  "servers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ${input:figma-token}"
      }
    }
  },
  "inputs": [
    {
      "id": "figma-token",
      "type": "promptString",
      "description": "Figma Personal Access Token",
      "password": true
    }
  ]
}
